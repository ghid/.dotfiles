#! /usr/bin/env bash

mapfile -t weekday << EOF
Sunday
Monday
Tuesday
Wednesday
Thursday
Friday
Saturday
EOF

dow=$(date +%w)

case $dow in
    1 | 2 | 3 | 4)
        til=$(date -d "$1 +9 hours" +%H:%M);;
    5)
        til=$(date -d "$1 +8 hours 30 minutes" +%H:%M);;
esac

s_epoch=$(date -d "$1" +%s)
n_epoch=$(date +%s --utc)
e_epoch=$(date -d "$til" +%s)
d_epoch=$((n_epoch - s_epoch))
l_epoch=$((e_epoch - n_epoch + 60))
o_epoch=$(( -1 * (e_epoch - n_epoch) ))
worked_h=$(date -d @${d_epoch} +%H --utc)
worked_m=$(date -d @${d_epoch} +%M --utc)


printf "It's %s, so you have to work til %sh.\n" "${weekday[dow]}" "$til"
printf "You've worked already for %sh and %sm.\n" "$worked_h" "$worked_m"
if [[ "$l_epoch" -lt 0 ]]; then
    todo_h=$(date -d @${o_epoch} +%H --utc)
    todo_m=$(date -d @${o_epoch} +%M --utc)
    printf "🍺 Wow! You're already on overtime for %sh and %sm!\n" "$todo_h" "$todo_m"
elif [[ "$l_epoch" -lt 60 ]]; then
    printf "🎉 Congrats. You're exactly done for today!\n"
else
    todo_h=$(date -d @${l_epoch} +%H --utc)
    todo_m=$(date -d @${l_epoch} +%M --utc)
    printf "💦 You have to work for another %sh and %sm...\n" "$todo_h" "$todo_m"
fi
